{
  "name": "form-copilot",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev:web": "ng serve --proxy-config proxy.conf.json",
    "dev:api": "vercel dev --listen 3000",
    "start:vercel": "vercel dev",
    "build": "ng build",
    "check:api": "tsc -p tsconfig.api.json --noEmit",
    "test:ci": "ng test --watch=false",
