{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "allowSyntheticDefaultImports": true
  },
  "include": ["api/**/*.ts", "src/shared/**/*.ts"]
}
